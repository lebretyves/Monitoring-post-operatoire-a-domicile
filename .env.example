COMPOSE_PROJECT_NAME=postop-monitoring

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_QOS=1
MQTT_KEEPALIVE=60
MQTT_USERNAME=
MQTT_PASSWORD=

INFLUX_URL=http://influxdb:8086
INFLUX_PORT=8086
INFLUX_ORG=postop
INFLUX_BUCKET=vitals
INFLUX_TOKEN=postop-monitoring-token
INFLUX_USERNAME=admin
INFLUX_PASSWORD=admin12345

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postop
POSTGRES_USER=postop
POSTGRES_PASSWORD=postop

BACKEND_PORT=8000
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173

SIMULATOR_TICK_SECONDS=5
ALERT_RULES_PATH=/app/config/alert_rules.json
SIMULATION_CONFIG_PATH=/app/config/simulation_scenarios.json
CASES_CATALOG_PATH=/app/config/cases_catalog.json
PATIENTS_SEED_PATH=/app/config/patients_seed.json
HISTORY_DEFAULT_HOURS=24

ENABLE_ML=true
ML_RUNTIME_DIR=/app/runtime/ml
ENABLE_LLM=false
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434
OLLAMA_MODEL=meditron-8b-local
OLLAMA_GGUF_HOST_DIR=C:/models
OLLAMA_GGUF_FILENAME=Meditron3-8B.Q4_0.gguf
OLLAMA_TIMEOUT_SECONDS=90

APP_TEST_MODE=false
